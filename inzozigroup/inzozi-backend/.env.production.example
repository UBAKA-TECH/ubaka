# Render Server Environment Variables

# The node environment mode
NODE_ENV="production"

# JWT Secret Key for user session token signing (should be a long random string)
JWT_SECRET="your_long_secure_jwt_secret_key_here"

# Supabase PostgreSQL Connection String (Transaction Pooler - Recommended)
# Replace [YOUR-PASSWORD] with the database password you set when creating the Supabase project.
DATABASE_URL="postgresql://postgres.ubhloolxahycdbvsztwo:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

