// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  planning
  development
  testing
  active
  archived
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  low
  medium
  high
  critical
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  code        String           @unique
  description String?
  isTechnical Boolean          @default(false)
  createdAt   DateTime         @default(now())

  // Relations
  employees   Employee[]
  permissions RolePermission[]
  delegations Delegation[]     @relation("DelegatedRole")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  code        String           @unique
  description String?
  createdAt   DateTime         @default(now())

  // Relations
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Employee {
  id            String      @id @default(uuid())
  name          String
  email         String      @unique
  password      String
  roleId        String?
  role          Role?       @relation(fields: [roleId], references: [id])
  title         String?     // e.g. "Lead React Dev", "UX/UI Designer"
  avatar        String?     // URL or color code
  department    String?     // e.g. "Engineering", "Product", "HR"
  location      String?     // e.g. "Remote", "Kigali", "Nairobi"
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  assignedTasks    Task[]               @relation("AssignedTasks")
  createdTasks     Task[]               @relation("CreatedTasks")
  messages         Message[]
  timeEntries      TimeEntry[]
  chatMembers      ChatRoomMember[]
  readReceipts     MessageReadReceipt[]
  createdChatRooms ChatRoom[]           @relation("CreatedChatRooms")

  // Delegations
  delegations      Delegation[]         @relation("UserDelegations")
  authorized       Delegation[]         @relation("AuthorizedDelegations")

  // HR Relations
  onboardingTasks  OnboardingChecklist[]
  approvalRequests ApprovalRequest[]    @relation("EmployeeRequests")
  reviewedRequests ApprovalRequest[]    @relation("ReviewedRequests")
  hardwareAssets   HardwareAsset[]
  certifications   Certification[]
}

// ─── HR Models ────────────────────────────────────────────────────────────────

model OnboardingChecklist {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  task        String    // "Sign Contract", "Complete Security Training", etc.
  category    String    @default("General") // "Legal", "IT Setup", "HR Admin", "Culture"
  isComplete  Boolean   @default(false)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([employeeId])
}

enum ApprovalType {
  time_off
  hardware
  expense
  other
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

model ApprovalRequest {
  id          String         @id @default(uuid())
  type        ApprovalType
  status      ApprovalStatus @default(pending)
  title       String
  description String?
  startDate   DateTime?      // For time_off
  endDate     DateTime?      // For time_off
  amount      Float?         // For expense (USD)
  employeeId  String
  employee    Employee       @relation("EmployeeRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewerId  String?
  reviewer    Employee?      @relation("ReviewedRequests", fields: [reviewerId], references: [id])
  reviewNote  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([employeeId])
  @@index([status])
}

enum AssetStatus {
  available
  assigned
  maintenance
  retired
}

model HardwareAsset {
  id            String      @id @default(uuid())
  name          String      // "MacBook Pro M3 Max"
  serialNumber  String      @unique
  type          String      // "laptop", "monitor", "phone", "tablet"
  brand         String?
  specs         String?     // "64GB RAM, 2TB SSD"
  status        AssetStatus @default(available)
  purchasedAt   DateTime?
  warrantyUntil DateTime?
  assignedToId  String?
  assignedTo    Employee?   @relation(fields: [assignedToId], references: [id])
  assignedAt    DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([assignedToId])
  @@index([status])
}

model SaasLicense {
  id           String    @id @default(uuid())
  tool         String    @unique // "GitHub Enterprise", "Figma", "Slack"
  category     String    @default("Productivity") // "DevOps", "Design", "Communication"
  totalSeats   Int       @default(0)
  usedSeats    Int       @default(0)
  costPerSeat  Float?    // Monthly USD per seat
  renewalDate  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Certification {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name       String    // "AWS Solutions Architect", "Kubernetes CKA"
  issuer     String?   // "Amazon Web Services", "CNCF"
  issuedAt   DateTime?
  expiresAt  DateTime?
  cost       Float?    // Education budget spent (USD)
  badgeUrl   String?   // Link to credential badge
  createdAt  DateTime  @default(now())

  @@index([employeeId])
}

model Delegation {
  id             String    @id @default(uuid())
  startDate      DateTime
  endDate        DateTime
  reason         String?
  isActive       Boolean   @default(true)
  customPermissions String?
  createdAt      DateTime  @default(now())

  // Relations
  employeeId     String
  employee       Employee  @relation("UserDelegations", fields: [employeeId], references: [id], onDelete: Cascade)

  targetRoleId   String
  targetRole     Role      @relation("DelegatedRole", fields: [targetRoleId], references: [id], onDelete: Cascade)

  authorizerId   String
  authorizer     Employee  @relation("AuthorizedDelegations", fields: [authorizerId], references: [id])

  @@index([employeeId])
  @@index([targetRoleId])
  @@index([authorizerId])
}

model Project {
  id            String        @id @default(uuid())
  name          String        @unique // e.g. Impressa, Linker, Homland, Gesture to Speech
  slug          String        @unique // e.g. impressa, linker, homland, gesture-to-speech
  description   String?
  status        ProjectStatus @default(planning)
  repositoryUrl String?
  liveUrl       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  tasks         Task[]
  timeEntries   TimeEntry[]
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(medium)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assigneeId  String?
  assignee    Employee?    @relation("AssignedTasks", fields: [assigneeId], references: [id])
  
  creatorId   String
  creator     Employee     @relation("CreatedTasks", fields: [creatorId], references: [id])

  @@index([projectId])
  @@index([assigneeId])
}

model Message {
  id           String               @id @default(uuid())
  content      String
  createdAt    DateTime             @default(now())
  
  // Relations
  roomId       String
  room         ChatRoom             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId     String
  sender       Employee             @relation(fields: [senderId], references: [id], onDelete: Cascade)
  readReceipts MessageReadReceipt[]

  @@index([senderId])
  @@index([roomId])
}

model ChatRoom {
  id                   String           @id @default(uuid())
  name                 String?          // null for 1-to-1 DMs
  isGroup              Boolean          @default(false)
  isEncrypted          Boolean          @default(false)
  encryptionValidation String?          // Encrypted string "valid" to verify key locally
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  
  // Relations
  createdById          String?
  createdBy            Employee?        @relation("CreatedChatRooms", fields: [createdById], references: [id])
  members              ChatRoomMember[]
  messages             Message[]
}

model ChatRoomMember {
  roomId     String
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  joinedAt   DateTime @default(now())
  role       String   @default("member") // "admin" or "member"

  @@id([roomId, employeeId])
}

model MessageReadReceipt {
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  readAt     DateTime @default(now())

  @@id([messageId, employeeId])
}

model TimeEntry {
  id          String   @id @default(uuid())
  description String
  startTime   DateTime @default(now())
  endTime     DateTime?
  minutes     Int      @default(0)
  createdAt   DateTime @default(now())

  // Relations
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([projectId])
}
