# INZOZI Group MIS Frontend Environment Variables
# Copy this file to .env or .env.local for local development, or set these on Vercel.

# URL of the backend server (without trailing slash)
# Local development default: http://localhost:5000
# Production default: Your hosted backend URL (e.g., https://inzozi-backend.onrender.com)
VITE_API_URL=http://localhost:5000
